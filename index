<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modman | Official Hub</title>
    <!-- Brand Fonts: Inter & Orbitron -->
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
        :root { --bg: #070b12; --card: #111827; --border: #1f2937; --text: #fff; --sub: #9ca3af; --acc: #3b82f6; }
        body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; margin: 0; padding: 40px 15px; display: flex; justify-content: center; min-height: 100vh; }
        .card { max-width: 550px; width: 100%; background: var(--card); border-radius: 16px; border: 1px solid var(--border); padding: 40px 30px; }
        .logo { text-align: center; margin-bottom: 25px; }
        .logo img { width: 100px; }
        h1 { font-family: 'Orbitron', sans-serif; text-transform: uppercase; text-align: center; }
        h2 { font-family: 'Orbitron', sans-serif; font-size: 16px; text-transform: uppercase; border-bottom: 1px solid var(--border); padding-bottom: 6px; }
        p, li { color: var(--sub); font-size: 15px; line-height: 1.7; }
        ul { list-style-type: none; padding: 0; }
        .site-link { color: var(--acc); text-decoration: none; font-family: 'Orbitron', sans-serif; }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo"><img src="https://imgur.com" alt="Modman Logo"></div>
        <h1>Modman</h1>
        <p>Official hub for apps, projects, and creative work.</p>
        <h2>About</h2>
        <p>Building, learning, and experimenting—from apps to content.</p>
        <h2>What You'll Find</h2>
        <ul>
            <li>📱 Apps/Tools</li>
            <li>💻 Projects</li>
            <li>🎥 Content</li>
            <li>🚀 Future Builds</li>
        </ul>
        <hr style="border:0; border-top:1px solid var(--border); margin:20px 0;">
        <a href="https://github.io" class="site-link">https://github.io</a>
    </div>
</body>
</html>
